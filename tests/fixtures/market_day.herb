func total_value(s, o):
  return s.2 * o.1
end

func restock_needed(s, o):
  return s.1 < o.1 or o.2
end

func main():
  let stall = ("seed", 7, 4)
  let alias = stall
  let order = (alias.0, 3, false)
  let stock = alias.1
  stock = stock - order.1
  let status = new_buffer()
  do append(status, 'o')
  do append(status, 'p')
  do append(status, 'e')
  do append(status, 'n')
  let orders = new_array(string)
  do add(orders, alias.0)
  do add(orders, "meal")
  if restock_needed(alias, order):
    return ("restock", freeze(status), alias.0, total_value(alias, order), stock, count(orders), get(orders, 0), get(orders, 1), true)
  else:
    return ("serve", freeze(status), alias.0, total_value(alias, order), stock, count(orders), get(orders, 0), get(orders, 1), false)
  end
end
