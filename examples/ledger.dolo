record Entry { label, amount }

fn surplus(stock, need) {
  let spare = stock - need
  if spare > 0 {
    return spare
  } else {
    return 0
  }
}

fn first_amount() {
  let e = Entry("seed", 9)
  return e.amount
}

fn main() {
  let e = Entry("seed", 9)
  let spare = surplus(e.amount, 5)
  return (e.label, spare, e.amount == 9)
}
