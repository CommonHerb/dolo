func closing_delimiter(name):
    if equal(name, ")"):
        return "("
    else:
        if equal(name, "}"):
            return "{"
        else:
            return "missing"
        end
    end
end

func key_list():
    return "),}"
end

func main():
    return (
        "closing-delimiters-candidate",
        closing_delimiter(")"),
        closing_delimiter("}"),
        closing_delimiter("missing")
    )
end
