func citizen_field_index(name):
    if equal(name, "name"):
        return 0
    else:
        if equal(name, "hunger"):
            return 1
        else:
            if equal(name, "coins"):
                return 2
            else:
                return 999
            end
        end
    end
end

func main():
    return (
        "record-field-index-candidate",
        citizen_field_index("hunger"),
        citizen_field_index("coins"),
        citizen_field_index("missing")
    )
end
